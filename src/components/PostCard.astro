---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'posts'>;
const post = Astro.props;
let date = post.data.lastmod;
if (post.data.hide?.includes('lastmod') && post.data.date) {
	date = post.data.date;
	if (post.data.hide?.includes('date')) {
		date = undefined;
	}
}
---

<article class="group border-b border-[#a0cef8]/45 py-7 last:border-b-0 dark:border-white/10 sm:py-8">
	<div class="flex flex-col gap-5 xl:flex-row xl:items-center">
		<div class="flex grow flex-col gap-4">
			<h2 class="text-3xl font-black leading-tight text-[#102a5f] sm:text-4xl dark:text-[#f2f5f8]">
				<a href={`/posts/${post.slug}`} aria-label={`Read post: ${post.data.title}`}>
					{post.data.title}
				</a>
			</h2>
			<p class="max-w-3xl text-base leading-7 text-[#204777] sm:text-lg dark:text-neutral-300">
				{post.data.description}
			</p>
			<div class="flex flex-wrap gap-x-4 gap-y-2 text-sm font-medium text-[#4f79ad] dark:text-neutral-400">
				{date && <time datetime={date.toISOString()}>{date.toLocaleDateString()}</time>}
				{
					(!post.data.hide || !post.data.hide.includes('tags')) &&
						post.data.tags?.map((tag) => (
							<a
								class="hover:text-[#102a5f] dark:hover:text-white"
								href={`/tags/${tag}/1`}
								aria-label={`More posts of tag ${tag}`}
							>
								#{tag}
							</a>
						))
				}
			</div>
		</div>
		{
			post.data.image && (
				<Picture
					class="aspect-[16/10] max-w-full rounded-2xl object-cover shadow-sm xl:w-72"
					src={post.data.image}
					formats={['avif', 'webp']}
					alt={`hero image for ${post.data.title}`}
				/>
			)
		}
	</div>
</article>
