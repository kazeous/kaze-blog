---
interface Props {
	currentNav?: string;
}
const { currentNav } = Astro.props;

const navs = [
	{ name: 'Home', href: '/' },
	{ name: 'Blog', href: '/blog' },
	{ name: 'About', href: '/about' },
];
---

<nav>
	<ul
		class="flex flex-col gap-2 rounded-3xl border border-[#a0cef8]/55 bg-white/55 p-1 font-default-sans shadow-[0_6px_16px_rgba(10,30,80,0.06)] backdrop-blur lg:flex-row dark:border-white/10 dark:bg-white/5"
	>
		{
			navs.map((nav) => (
				<li>
					<a
						class="inline-flex min-h-9 items-center rounded-full px-4 text-sm font-semibold text-[#2c62b4] hover:bg-white hover:text-[#102a5f] aria-[current=page]:bg-sky-300 aria-[current=page]:text-[#102a5f] dark:text-neutral-300 dark:hover:bg-white/10 dark:hover:text-white dark:aria-[current=page]:bg-sky-400 dark:aria-[current=page]:text-neutral-950"
						href={nav.href}
						aria-current={currentNav === nav.name ? 'page' : undefined}
						aria-label={`Navigate to ${nav.name}`}
					>
						{nav.name}
					</a>
				</li>
			))
		}
	</ul>
</nav>
