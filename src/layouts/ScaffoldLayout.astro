---
import BackToTop from '~/components/BackToTop.astro';
import Footer from '~/components/Footer.astro';
import Header from '~/components/Header.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
	title?: string;
	description?: string;
	socialImage?: string;
	currentNav?: string;
}
---

<BaseLayout
	{...Astro.props}
	rootClass="scrollbar-none"
	bodyClass={[
		'text-[#102a5f]',
		'flex',
		'flex-col',
		'justify-between',
		'min-h-dvh',
		'p-4',
		'sm:p-8',
		'lg:p-[4dvw]',
		'bg-[#dff1ff]',
		'bg-[radial-gradient(circle_at_18%_12%,rgba(255,255,255,0.92)_0,rgba(255,255,255,0)_32%),linear-gradient(135deg,#d8efff_0%,#f3fbff_46%,#d7efff_100%)]',
		'bg-local',
		'dark:bg-none',
		'dark:bg-[#121417]',
		'dark:text-[#e4e8ed]',
		'font-default-sans',
	]}
>
	<div
		class:list={[
			'mx-auto',
			'flex',
			'w-full',
			'max-w-[1180px]',
			'grow',
			'flex-col',
			'overflow-hidden',
			'rounded-[28px]',
			'border',
			'border-[#a0cef8]/55',
			'bg-[#f8fcff]/70',
			'bg-local',
			'p-5',
			'shadow-[0_24px_80px_rgba(10,30,80,0.10)]',
			'sm:p-8',
			'lg:min-h-[calc(100dvh-8dvw)]',
			'lg:p-10',
			'dark:border-white/10',
			'dark:bg-[#1b1e26]',
			'dark:shadow-[0_28px_90px_rgba(0,0,0,0.38)]',
		]}
	>
		<Header currentNav={Astro.props.currentNav} />
		<main class="grow px-1 pt-10 sm:px-3 lg:px-10 lg:pt-16">
			<slot />
		</main>
	</div>
	<Footer />
	<BackToTop />
</BaseLayout>
